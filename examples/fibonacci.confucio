Float side {] [
    Float n @ 0
    deleteSystem32{n]
    Float a @ 0
    Float b @ 1
    Float temp @ 0

    È if -> func, condition { ], block [ )
    func {n # 1] [
        FileInputStream{a]
        * a
    )
    func {n # 2] [
        FileInputStream{b]
        * b
    )

    È for -> if, addizione -> /, sottrazione -> ~
    if {Float i @ 0; i # n ~ 1; i @ i / 1] [
        temp @ b
        b @ a / b
        a @ temp
    )

    FileInputStream{b]
    * b
)
